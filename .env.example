# Required
HELIUS_API_KEY=your_helius_api_key_here

# Required — auth token for the web UI / API (min 16 chars).
# Generate with: openssl rand -hex 32
API_TOKEN=change_me_generate_with_openssl_rand

# Docker port binding. Default 127.0.0.1 (localhost only).
# Set to 0.0.0.0 for LAN access (API is token-protected).
#BIND_ADDR=0.0.0.0

# Path where the keypair JSON is stored.
# Can be set here OR created/imported via the web UI.
# Docker default: /app/wallet/keypair.json (mounted volume)
WALLET_KEYPAIR_PATH=./wallet/keypair.json

# Optional overrides (defaults shown)

# Priority fee for rebalance swaps
PRIORITY_FEE_LAMPORTS=100000

# Let Jupiter pick per-route slippage up to the cap below
REBALANCE_DYNAMIC_SLIPPAGE=true

# Slippage cap when dynamic (above) is on; fixed slippage when off
REBALANCE_SLIPPAGE_BPS=300

PORT=3420
